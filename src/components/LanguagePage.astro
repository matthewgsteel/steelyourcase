---
import CTA from '@/components/CTA.astro';
import type { FaqItem, PageSection } from '@/lib/site';

interface Props {
  headline: string;
  intro: string;
  lines: string[];
  sections?: PageSection[];
  faqs?: FaqItem[];
}

const { headline, intro, lines, sections = [], faqs = [] } = Astro.props;
---

<section class="page-hero container">
  <div class="page-hero__content">
    <p class="hero-kicker">Multilingual routing</p>
    <h1>{headline}</h1>
    <p class="page-subhead">{intro}</p>
  </div>
  <aside class="page-summary-card" data-nosnippet>
    <h2>How this page helps</h2>
    <ul>
      <li>Collects safe intake details in the preferred language when possible</li>
      <li>Flags urgent deadlines and routes the file toward attorney review</li>
      <li>Keeps public language simple, direct, and record-focused</li>
    </ul>
  </aside>
</section>

<section class="content-grid container">
  <div class="content-flow">
    <article class="language-page-content">
      {lines.map((line, index) => (
        <section class="content-block">
          <h2>{index === 0 ? 'First route' : index === 1 ? 'Case posture' : 'Urgent timing'}</h2>
          <p>{line}</p>
        </section>
      ))}

      {sections.map((section) => (
        <section class="content-block">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </section>
      ))}
    </article>
  </div>

  <aside class="sidebar-panel" data-nosnippet>
    <h2>Need review now?</h2>
    <p>
      Use the secure contact form to tell the office the language, the deadline, and the type of
      immigration matter that needs review.
    </p>
    <a class="button button-secondary" href="/contact/">Schedule a Consultation</a>
  </aside>
</section>

{faqs.length > 0 && (
  <section class="faq-section container">
    <h2>Frequently Routed Questions</h2>
    <div class="faq-grid">
      {faqs.map((faq) => (
        <article class="faq-card">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </article>
      ))}
    </div>
  </section>
)}

<CTA
  title="Bring the file. Bring the facts."
  copy="Use the secure intake lane when you want the office to review the record, the deadline, and the right next move."
/>