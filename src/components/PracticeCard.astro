---
interface Props {
  title: string;
  copy: string;
  href: string;
  cta: string;
  image: string;
}

const { title, copy, href, cta, image } = Astro.props;
---

<article class="practice-card">
  <img src={image} alt="" loading="lazy" decoding="async" width="640" height="520" />
  <div class="practice-card__content">
    <h3>{title}</h3>
    <p>{copy}</p>
    <a class="text-link" href={href}>{cta}</a>
  </div>
</article>
