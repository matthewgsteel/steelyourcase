---
import { firm, immigrationNav, primaryNav } from '@/lib/site';
---

<header class="site-header">
  <div class="topbar">
    <a class="brand" href="/" aria-label={`${firm.name} home`}>
      <img src="/brand/crest-logo.webp" alt="" width="68" height="68" loading="eager" decoding="async" />
      <div>
        <p class="brand-mark">Put it on Steel</p>
        <strong>{firm.name}</strong>
      </div>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      <ul>
        {primaryNav.map((item) => (
          item.label === 'Immigration' ? (
            <li class="nav-has-menu">
              <a href={item.href}>{item.label}</a>
              <div class="nav-menu">
                <ul>
                  {immigrationNav.map((child) => (
                    <li><a href={child.href}>{child.label}</a></li>
                  ))}
                </ul>
              </div>
            </li>
          ) : (
            <li><a href={item.href}>{item.label}</a></li>
          )
        ))}
      </ul>
    </nav>

    <a class="header-call" href={`tel:${firm.phoneNumeric}`}>Call {firm.phoneDisplay}</a>

    <details class="mobile-nav">
      <summary aria-label="Open navigation">Menu</summary>
      <div class="mobile-nav-panel">
        <ul>
          {primaryNav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
        <details>
          <summary>Immigration Services</summary>
          <ul>
            {immigrationNav.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </details>
      </div>
    </details>
  </div>

  <div class="mobile-sticky-cta" aria-label="Quick actions">
    <a href={`tel:${firm.phoneNumeric}`}>Call</a>
    <a href="/contact/">Consultation</a>
  </div>
</header>
