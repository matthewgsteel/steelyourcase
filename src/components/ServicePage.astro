---
import CTA from '@/components/CTA.astro';
import SealDivider from '@/components/SealDivider.astro';
import type { ServicePageData } from '@/lib/site';

interface Props {
  page: ServicePageData;
}

const { page } = Astro.props;
---

<section class="page-hero container">
  <div class="page-hero__content">
    <p class="hero-kicker">{page.intro}</p>
    <h1>{page.headline}</h1>
    <p class="page-subhead">{page.subhead}</p>
  </div>
  <aside class="page-summary-card" data-nosnippet>
    <h2>What this page covers</h2>
    <ul>
      {page.keyPoints.map((point) => (
        <li>{point}</li>
      ))}
    </ul>
  </aside>
</section>

<SealDivider />

<section class="content-grid container">
  <div class="content-flow">
    {page.sections.map((section) => (
      <article class="content-block">
        <h2>{section.title}</h2>
        <p>{section.body}</p>
        {section.points && (
          <ul class="bullet-list">
            {section.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        )}
        {section.links && (
          <div class="text-link-group">
            {section.links.map((link) => (
              <a class="text-link" href={link.href}>{link.label}</a>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>

  <aside class="sidebar-panel" data-nosnippet>
    <h2>Route the file</h2>
    <p>
      Use the secure contact form when you want the office to review the matter, flag a deadline,
      or identify the clean next step.
    </p>
    <a class="button button-secondary" href={page.ctaHref ?? '/contact/'}>
      {page.ctaLabel ?? 'Schedule a Consultation'}
    </a>
    {page.relatedLinks && (
      <>
        <h3>Related pages</h3>
        <ul class="sidebar-links">
          {page.relatedLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </>
    )}
  </aside>
</section>

{page.faqs.length > 0 && (
  <section class="faq-section container">
    <h2>Frequently Routed Questions</h2>
    <div class="faq-grid">
      {page.faqs.map((faq) => (
        <article class="faq-card">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </article>
      ))}
    </div>
  </section>
)}

{page.disclaimer && (
  <section class="notice-strip container" data-nosnippet>
    <p>{page.disclaimer}</p>
  </section>
)}

<CTA
  title="Bring the file. Bring the facts."
  copy="Use the secure intake lane when you want the office to review the record, the deadline, and the right next move."
  href={page.ctaHref}
  label={page.ctaLabel}
/>
