---
import CTA from '@/components/CTA.astro';
import SealDivider from '@/components/SealDivider.astro';
import type { ServicePageData } from '@/lib/site';

interface Props {
  page: ServicePageData;
  editable?: boolean;
}

const { page, editable = false } = Astro.props;
const summaryTitle = page.summaryTitle ?? 'What This Page Covers';
const sidebarTitle = page.sidebarTitle ?? 'Route the File';
const sidebarCopy =
  page.sidebarCopy ??
  'Use the secure contact form when you want the office to review the matter, flag a deadline, or identify the clean next step.';
const faqTitle = page.faqTitle ?? 'Frequently Routed Questions';
const ctaPanel = page.ctaPanel ?? {
  kicker: 'The Next Move',
  title: 'Bring the file. Bring the facts.',
  copy: 'Use the secure intake lane when you want the office to review the record, the deadline, and the right next move.',
  label: page.ctaLabel ?? 'Request a Consultation',
  href: page.ctaHref ?? '/contact/',
};
---

<section class="page-hero container">
  <div class="page-hero__content">
    <p class="hero-kicker" data-editable={editable ? 'text' : undefined} data-prop={editable ? 'intro' : undefined}>
      {page.intro}
    </p>
    <h1 data-editable={editable ? 'text' : undefined} data-prop={editable ? 'headline' : undefined}>
      {page.headline}
    </h1>
    <p class="page-subhead" data-editable={editable ? 'text' : undefined} data-prop={editable ? 'subhead' : undefined}>
      {page.subhead}
    </p>
  </div>
  <aside class="page-summary-card">
    <h2 data-editable={editable ? 'text' : undefined} data-prop={editable ? 'summaryTitle' : undefined}>
      {summaryTitle}
    </h2>
    <ul data-editable={editable ? 'array' : undefined} data-prop={editable ? 'keyPoints' : undefined}>
      {page.keyPoints.map((point) => (
        <li data-editable={editable ? 'array-item' : undefined}>
          <span data-editable={editable ? 'text' : undefined} data-prop={editable ? 'text' : undefined}>{point}</span>
        </li>
      ))}
    </ul>
  </aside>
</section>

<SealDivider />

<section class="content-grid container">
  <div class="content-flow" data-editable={editable ? 'array' : undefined} data-prop={editable ? 'sections' : undefined}>
    {page.sections.map((section) => (
      <article class="content-block" data-editable={editable ? 'array-item' : undefined}>
        <h2 data-editable={editable ? 'text' : undefined} data-prop={editable ? 'title' : undefined}>
          {section.title}
        </h2>
        <p data-editable={editable ? 'text' : undefined} data-prop={editable ? 'body' : undefined}>{section.body}</p>
        {section.points && (
          <ul class="bullet-list" data-editable={editable ? 'array' : undefined} data-prop={editable ? 'points' : undefined}>
            {section.points.map((point) => (
              <li data-editable={editable ? 'array-item' : undefined}>
                <span data-editable={editable ? 'text' : undefined} data-prop={editable ? 'text' : undefined}>
                  {point}
                </span>
              </li>
            ))}
          </ul>
        )}
        {section.links && (
          <div class="text-link-group" data-editable={editable ? 'array' : undefined} data-prop={editable ? 'links' : undefined}>
            {section.links.map((link) => (
              <a class="text-link" href={link.href} data-editable={editable ? 'array-item' : undefined}>
                <span data-editable={editable ? 'text' : undefined} data-prop={editable ? 'label' : undefined}>
                  {link.label}
                </span>
              </a>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>

  <aside class="sidebar-panel">
    <h2 data-editable={editable ? 'text' : undefined} data-prop={editable ? 'sidebarTitle' : undefined}>
      {sidebarTitle}
    </h2>
    <p data-editable={editable ? 'text' : undefined} data-prop={editable ? 'sidebarCopy' : undefined}>
      {sidebarCopy}
    </p>
    <a class="button button-secondary" href={page.ctaHref ?? '/contact/'}>
      {page.ctaLabel ?? 'Request a Consultation'}
    </a>
    {page.relatedLinks && (
      <>
        <h3>Related Pages</h3>
        <ul class="sidebar-links" data-editable={editable ? 'array' : undefined} data-prop={editable ? 'relatedLinks' : undefined}>
          {page.relatedLinks.map((link) => (
            <li data-editable={editable ? 'array-item' : undefined}>
              <a href={link.href}>
                <span data-editable={editable ? 'text' : undefined} data-prop={editable ? 'label' : undefined}>
                  {link.label}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </>
    )}
  </aside>
</section>

{page.faqs.length > 0 && (
  <section class="faq-section container">
    <h2 data-editable={editable ? 'text' : undefined} data-prop={editable ? 'faqTitle' : undefined}>{faqTitle}</h2>
    <div class="faq-grid" data-editable={editable ? 'array' : undefined} data-prop={editable ? 'faqs' : undefined}>
      {page.faqs.map((faq) => (
        <article class="faq-card" data-editable={editable ? 'array-item' : undefined}>
          <h3 data-editable={editable ? 'text' : undefined} data-prop={editable ? 'question' : undefined}>
            {faq.question}
          </h3>
          <p data-editable={editable ? 'text' : undefined} data-prop={editable ? 'answer' : undefined}>
            {faq.answer}
          </p>
        </article>
      ))}
    </div>
  </section>
)}

{page.disclaimer && (
  <section class="notice-strip container">
    <p data-editable={editable ? 'text' : undefined} data-prop={editable ? 'disclaimer' : undefined}>
      {page.disclaimer}
    </p>
  </section>
)}

{
  editable ? (
    <editable-component data-prop="cta" data-component="cta">
      <CTA
        editable
        kicker={ctaPanel.kicker}
        title={ctaPanel.title}
        copy={ctaPanel.copy}
        href={ctaPanel.href}
        label={ctaPanel.label}
      />
    </editable-component>
  ) : (
    <CTA
      kicker={ctaPanel.kicker}
      title={ctaPanel.title}
      copy={ctaPanel.copy}
      href={ctaPanel.href}
      label={ctaPanel.label}
    />
  )
}
