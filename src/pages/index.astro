---
import CTA from '@/components/CTA.astro';
import Hero from '@/components/Hero.astro';
import PracticeCard from '@/components/PracticeCard.astro';
import SealDivider from '@/components/SealDivider.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { organizationSchema } from '@/lib/seo';

const [homeEntry] = await getCollection('homepage');

if (!homeEntry) {
  throw new Error('Homepage content entry is missing.');
}

const homePage = homeEntry.data;
---

<BaseLayout
  title={homePage.seoTitle}
  description={homePage.metaDescription}
  path="/"
  schemas={organizationSchema()}
>
  <editable-component data-prop="hero" data-component="hero">
    <Hero {...homePage.hero} />
  </editable-component>

  <section class="container">
    <div class="practice-grid" data-editable="array" data-prop="practiceCards">
      {homePage.practiceCards.map((card) => (
        <div data-editable="array-item">
          <editable-component data-prop="" data-component="practice-card">
            <PracticeCard {...card} />
          </editable-component>
        </div>
      ))}
    </div>
  </section>

  <SealDivider />

  <section class="container">
    <div class="content-block">
      <p class="hero-kicker" data-editable="text" data-prop="steelMethodIntro.kicker">
        {homePage.steelMethodIntro.kicker}
      </p>
      <h2 class="section-heading" data-editable="text" data-prop="steelMethodIntro.title">
        {homePage.steelMethodIntro.title}
      </h2>
      <p data-editable="text" data-prop="steelMethodIntro.copy">{homePage.steelMethodIntro.copy}</p>
      <div class="steel-method-grid" data-editable="array" data-prop="steelMethod">
        {homePage.steelMethod.map((step) => (
          <article class="steel-method-card" data-editable="array-item">
            <h3 data-editable="text" data-prop="title">{step.title}</h3>
            <p data-editable="text" data-prop="copy">{step.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container">
    <div class="content-block">
      <p class="hero-kicker" data-editable="text" data-prop="immigrationHighlight.kicker">
        {homePage.immigrationHighlight.kicker}
      </p>
      <h2 class="section-heading" data-editable="text" data-prop="immigrationHighlight.title">
        {homePage.immigrationHighlight.title}
      </h2>
      <p data-editable="text" data-prop="immigrationHighlight.copy">{homePage.immigrationHighlight.copy}</p>
      <div class="feature-links" data-editable="array" data-prop="immigrationHighlight.links">
        {homePage.immigrationHighlight.links.map((item) => (
          <a class="feature-link-card" href={item.href} data-editable="array-item">
            <h3 data-editable="text" data-prop="label">{item.label}</h3>
            <p data-editable="text" data-prop="summary">{item.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container">
    <div class="content-block">
      <p class="hero-kicker" data-editable="text" data-prop="languages.kicker">
        {homePage.languages.kicker}
      </p>
      <h2 class="section-heading" data-editable="text" data-prop="languages.title">
        {homePage.languages.title}
      </h2>
      <p data-editable="text" data-prop="languages.copy">{homePage.languages.copy}</p>
      <ul class="trust-strip" data-editable="array" data-prop="languages.list">
        {homePage.languages.list.map((item) => (
          <li data-editable="array-item">
            <span data-editable="text" data-prop="text">{item.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <editable-component data-prop="footerCta" data-component="cta">
    <CTA
      editable
      kicker={homePage.footerCta.kicker}
      title={homePage.footerCta.title}
      copy={homePage.footerCta.copy}
      href={homePage.footerCta.href}
      label={homePage.footerCta.label}
    />
  </editable-component>
</BaseLayout>
