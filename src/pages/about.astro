---
import CTA from '@/components/CTA.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { breadcrumbSchema } from '@/lib/seo';

const [aboutEntry] = await getCollection('about-page');

if (!aboutEntry) {
  throw new Error('About page content entry is missing.');
}

const aboutPage = aboutEntry.data;
---

<BaseLayout
  title={aboutPage.title}
  description={aboutPage.metaDescription}
  path="/about/"
  schemas={[breadcrumbSchema([{ href: '/', label: 'Home' }, { href: '/about/', label: 'About' }])]}
>
  <section class="page-hero container">
    <div class="page-hero__content">
      <p class="hero-kicker" data-editable="text" data-prop="heroKicker">{aboutPage.heroKicker}</p>
      <h1 data-editable="text" data-prop="heroTitle">{aboutPage.heroTitle}</h1>
      <p class="page-subhead" data-editable="text" data-prop="heroSubhead">{aboutPage.heroSubhead}</p>
    </div>
    <aside class="page-summary-card">
      <h2 data-editable="text" data-prop="summaryTitle">{aboutPage.summaryTitle}</h2>
      <ul data-editable="array" data-prop="summaryItems">
        {aboutPage.summaryItems.map((item) => (
          <li data-editable="array-item">
            <span data-editable="text" data-prop="text">{item.text}</span>
          </li>
        ))}
      </ul>
    </aside>
  </section>

  <section class="content-grid container">
    <div class="content-flow" data-editable="array" data-prop="sections">
      {aboutPage.sections.map((section) => (
        <article class="content-block" data-editable="array-item">
          <h2 data-editable="text" data-prop="title">{section.title}</h2>
          <p data-editable="text" data-prop="body">{section.body}</p>
        </article>
      ))}
    </div>

    <aside class="sidebar-panel">
      <h2 data-editable="text" data-prop="sidebarTitle">{aboutPage.sidebarTitle}</h2>
      <div data-editable="array" data-prop="sidebarLines">
        {aboutPage.sidebarLines.map((line) => (
          <p data-editable="array-item">
            <span data-editable="text" data-prop="text">{line.text}</span>
          </p>
        ))}
      </div>
      <a class="button button-secondary" href={aboutPage.sidebarCta.href} data-editable="text" data-prop="sidebarCta.label">
        {aboutPage.sidebarCta.label}
      </a>
    </aside>
  </section>

  <editable-component data-prop="footerCta" data-component="cta">
    <CTA
      editable
      kicker={aboutPage.footerCta.kicker}
      title={aboutPage.footerCta.title}
      copy={aboutPage.footerCta.copy}
      href={aboutPage.footerCta.href}
      label={aboutPage.footerCta.label}
    />
  </editable-component>
</BaseLayout>
