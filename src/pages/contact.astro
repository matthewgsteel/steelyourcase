---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  contactConsentText,
  languageOptions,
  matterTypes,
  practiceAreas,
  urgencyOptions,
} from '@/lib/forms';
import { breadcrumbSchema } from '@/lib/seo';
import { firm } from '@/lib/site';

const defaultMatterTypes = matterTypes.Immigration;
const [contactEntry] = await getCollection('contact-page');

if (!contactEntry) {
  throw new Error('Contact page content entry is missing.');
}

const contactPage = contactEntry.data;
---

<BaseLayout
  title={contactPage.title}
  description={contactPage.metaDescription}
  path="/contact/"
  schemas={[breadcrumbSchema([{ href: '/', label: 'Home' }, { href: '/contact/', label: 'Contact' }])]}
>
  <section class="page-hero container">
    <div class="page-hero__content">
      <p class="hero-kicker" data-editable="text" data-prop="heroKicker">{contactPage.heroKicker}</p>
      <h1 data-editable="text" data-prop="heroTitle">{contactPage.heroTitle}</h1>
      <p class="page-subhead" data-editable="text" data-prop="heroSubhead">{contactPage.heroSubhead}</p>
    </div>
    <aside class="page-summary-card">
      <h2 data-editable="text" data-prop="directContactTitle">{contactPage.directContactTitle}</h2>
      <ul>
        <li><a href={`tel:${firm.phoneNumeric}`}>{firm.phoneDisplay}</a></li>
        <li><a href={`mailto:${firm.email}`}>{firm.email}</a></li>
        <li>{firm.addressLines[0]}</li>
        <li>{firm.addressLines[1]}</li>
      </ul>
    </aside>
  </section>

  <section class="content-grid container">
    <div class="content-block">
      <h2 class="section-heading" data-editable="text" data-prop="formSectionTitle">
        {contactPage.formSectionTitle}
      </h2>
      <form class="content-flow" data-contact-form>
        <div class="faq-grid">
          <label>
            Name
            <input name="name" type="text" autocomplete="name" required />
          </label>
          <label>
            Email
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            Phone
            <input name="phone" type="tel" autocomplete="tel" required />
          </label>
          <label>
            Preferred Language
            <select name="preferredLanguage">
              {languageOptions.map((item) => (
                <option value={item}>{item}</option>
              ))}
            </select>
          </label>
          <label>
            Practice Area
            <select name="practiceArea">
              {practiceAreas.map((item) => (
                <option value={item}>{item}</option>
              ))}
            </select>
          </label>
          <label>
            Matter Type
            <select name="matterType">
              {defaultMatterTypes.map((item) => (
                <option value={item}>{item}</option>
              ))}
            </select>
          </label>
          <label>
            Urgency
            <select name="urgency">
              {urgencyOptions.map((item) => (
                <option value={item}>{item}</option>
              ))}
            </select>
          </label>
          <label>
            Deadline
            <input
              name="deadline"
              type="text"
              placeholder="Court date, hearing date, audit deadline, or agency notice deadline"
            />
          </label>
        </div>

        <label>
          Short Message
          <textarea
            name="shortMessage"
            rows="6"
            placeholder="Describe what happened, what deadline exists, and what kind of review you need."
            required
          ></textarea>
        </label>

        <label>
          <input name="consent" type="checkbox" required />
          <span>{contactConsentText}</span>
        </label>

        <div class="turnstile-slot" data-turnstile-widget="contact"></div>
        <button class="button button-primary" type="submit" data-editable="text" data-prop="submitLabel">
          {contactPage.submitLabel}
        </button>
        <p class="record-room__status" data-contact-status data-editable="text" data-prop="statusMessage">
          {contactPage.statusMessage}
        </p>
      </form>
    </div>

    <aside class="sidebar-panel">
      <h2 data-editable="text" data-prop="bestForTitle">{contactPage.bestForTitle}</h2>
      <ul class="bullet-list" data-editable="array" data-prop="bestForItems">
        {contactPage.bestForItems.map((item) => (
          <li data-editable="array-item">
            <span data-editable="text" data-prop="text">{item.text}</span>
          </li>
        ))}
      </ul>

      <h3 data-editable="text" data-prop="doNotSendTitle">{contactPage.doNotSendTitle}</h3>
      <ul class="bullet-list" data-editable="array" data-prop="doNotSendItems">
        {contactPage.doNotSendItems.map((item) => (
          <li data-editable="array-item">
            <span data-editable="text" data-prop="text">{item.text}</span>
          </li>
        ))}
      </ul>
    </aside>
  </section>

  <section class="notice-strip container">
    <p data-editable="text" data-prop="privacyNotice">{contactPage.privacyNotice}</p>
  </section>
</BaseLayout>

<script>
  import '@/scripts/contact-form';
</script>
