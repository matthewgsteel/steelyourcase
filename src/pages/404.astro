---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Steel & Associates, A Professional Law Corporation"
  description="The requested page was not found."
  canonicalPath="/404/"
>
  <section class="page-hero container">
    <div class="page-hero__content">
      <p class="hero-kicker">Page Not Found</p>
      <h1>This page is not on the record.</h1>
      <p class="page-subhead">
        The page you requested is not available. Use the main navigation or contact page to reach the office.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/">Return Home</a>
        <a class="button button-secondary" href="/contact/">Contact the Office</a>
      </div>
    </div>
  </section>
</BaseLayout>
